{
  "name": "cc-switch-protocol-bridge",
  "version": "0.1.0",
  "description": "Lightweight Anthropic ↔ OpenAI protocol bridge for Linux servers. Lets Claude Code use domestic LLM providers (MiniMax, Alibaba, Volcengine) that only expose OpenAI-compatible endpoints.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "cc-switch": "dist/cli.js"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "build": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile=dist/cc-switch",
    "build:debug": "bun build src/cli.ts --target=node --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "bunx biome check src/ test/",
    "lint:fix": "bunx biome check --write --unsafe src/ test/",
    "format": "bunx biome format --write src/ test/",
    "start": "bun run src/cli.ts serve"
  },
  "keywords": [
    "anthropic",
    "openai",
    "claude-code",
    "protocol-bridge",
    "minimax",
    "linux"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.6.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fastify": "^5.1.0",
    "js-yaml": "^4.1.0",
    "jsonc-parser": "^3.3.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  }
}